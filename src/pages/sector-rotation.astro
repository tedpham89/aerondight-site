---
import "../styles/article.css";

import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";

interface Week {
	week_end: string;
	regime: string;
	votes_on: number;
	votes_total: number;
	rotation_in: string[];
	rotation_out: string[];
}

const modules = import.meta.glob<{ default: Week }>("../data/rotation/*.json", {
	eager: true,
});
const weeks = Object.values(modules)
	.map((m) => m.default)
	.sort((a, b) => b.week_end.localeCompare(a.week_end));

const current = weeks[0] ?? null;
const older = weeks.slice(1);

const fmtDate = (iso: string) =>
	new Date(`${iso}T00:00:00`).toLocaleDateString("en-US", {
		weekday: "long",
		year: "numeric",
		month: "long",
		day: "numeric",
	});

const regimeClass = (regime: string) =>
	regime === "Risk-On" ? "risk-on" : regime === "Risk-Off" ? "risk-off" : "transitional";
---

<Layout
	title="Sector Rotation"
	description="Weekly sector rotation signals — market risk regime and sectors freshly rotating in or out, updated after each Friday close."
>
	<div class="left" slot="left">
		<Card class="toc-card">
			<h2 class="no-mt">On this page</h2>
			<ol>
				<li class="toc-li"><a href="#_top" class="active">This Week</a></li>
				<li class="toc-li"><a href="#history">History</a></li>
				<li class="toc-li"><a href="#key-rules">Key Rules</a></li>
			</ol>
		</Card>
	</div>
	<article slot="right" data-pagefind-body>
		<Card>
			<h1 class="no-mt" id="_top" style="scroll-margin-top: 2rem;">Sector Rotation</h1>
			<p style="color: #c7c7c7; margin-top: 0.5rem;">
				Weekly market risk status and sector rotations, updated after Friday's close.
			</p>

			{current ? (
				<div class="week-block main">
					<p class="week-label">Week ending {fmtDate(current.week_end)}</p>
					<div class={`regime-banner ${regimeClass(current.regime)}`}>
						<Icon
							type="lucide"
							name={current.regime === "Risk-On" ? "trending-up" : current.regime === "Risk-Off" ? "trending-down" : "move-horizontal"}
							width={28}
							height={28}
						/>
						<span class="regime-name">{current.regime}</span>
					</div>
					<div class="rotation-row">
						<div class="rotation-box">
							<h3 class="no-mt rot-in-title">Rotation In</h3>
							{current.rotation_in.length ? (
								<ul class="sector-list">
									{current.rotation_in.map((s) => (
										<li class="sector-chip in">{s}</li>
									))}
								</ul>
							) : (
								<p class="none-note">None this week</p>
							)}
						</div>
						<div class="rotation-box">
							<h3 class="no-mt rot-out-title">Rotation Out</h3>
							{current.rotation_out.length ? (
								<ul class="sector-list">
									{current.rotation_out.map((s) => (
										<li class="sector-chip out">{s}</li>
									))}
								</ul>
							) : (
								<p class="none-note">None this week</p>
							)}
						</div>
					</div>
				</div>
			) : (
				<p class="none-note">No rotation data published yet.</p>
			)}

			{older.length > 0 && (
				<>
					<h2 id="history" style="scroll-margin-top: 4rem;">History</h2>
					<div class="history-scroll">
						<table class="history-table">
							<thead>
								<tr>
									<th>Week ending</th>
									<th>Regime</th>
									<th>Rotation in</th>
									<th>Rotation out</th>
								</tr>
							</thead>
							<tbody>
								{older.map((w) => (
									<tr>
										<td>{w.week_end}</td>
										<td><span class={`regime-dot ${regimeClass(w.regime)}`}></span>{w.regime}</td>
										<td>{w.rotation_in.join(", ") || "—"}</td>
										<td>{w.rotation_out.join(", ") || "—"}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</>
			)}

			<h2 id="key-rules" style="scroll-margin-top: 4rem;">Key Rules</h2>
			<p>
				When the risk regime is <strong>Risk-On</strong> on a Friday and a sector is rotating in,
				statistics since 2015 show a high chance of beating the S&amp;P 500 by buying that sector's
				leading stocks on Monday and holding for the next three weeks. Rotations that occur in
				Transitional or Risk-Off regimes have not shown that edge and are tracked for reference only.
			</p>
			<p class="disclaimer">
				<strong>Disclaimer:</strong> This is not investment advice. Everything on this page is for
				educational purposes only. Invest at your own risk.
			</p>
		</Card>
	</article>
</Layout>
<script src="../scripts/toc.ts"></script>
<style>
	.week-label {
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		color: #c7c7c7;
		margin-bottom: 0.75rem;
	}

	.week-block.main {
		margin-top: 1.5rem;
	}

	.regime-banner {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border: 1px solid;
		padding: 1rem 1.25rem;
		margin-bottom: 1rem;
	}

	.regime-banner.small {
		padding: 0.5rem 1rem;
	}

	.regime-name {
		font-size: 1.5em;
		font-weight: 800;
	}

	.regime-banner.small .regime-name {
		font-size: 1.125em;
	}

	.disclaimer {
		color: #888;
		font-size: 0.875rem;
		border-top: 1px solid #353535;
		padding-top: 1rem;
		margin-top: 1.5rem;
	}

	.risk-on { border-color: #16c79a; color: #16c79a; }
	.transitional { border-color: #f0a500; color: #f0a500; }
	.risk-off { border-color: #e94560; color: #e94560; }

	.rotation-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	@media screen and (max-width: 640px) {
		.rotation-row {
			grid-template-columns: 1fr;
		}
	}

	.rotation-box {
		border: 1px solid #353535;
		padding: 1rem;
	}

	.rot-in-title { color: #16c79a; margin-bottom: 0.75rem; }
	.rot-out-title { color: #e94560; margin-bottom: 0.75rem; }

	.sector-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.sector-chip {
		border: 1px solid #353535;
		padding: 0.25rem 0.6rem;
		font-size: 0.925rem;
		font-family: "Geist Mono", "Courier New", Courier, monospace;
	}

	.sector-chip.in { border-color: #16c79a; }
	.sector-chip.out { border-color: #e94560; }

	.none-note {
		color: #888;
		font-style: italic;
	}

	.history-scroll {
		max-height: 22rem;
		overflow-y: auto;
		overflow-x: auto;
		border: 1px solid #353535;
	}

	.history-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.925rem;
	}

	.history-table th,
	.history-table td {
		border: 1px solid #353535;
		padding: 0.5rem 0.75rem;
		text-align: left;
		vertical-align: top;
	}

	/* date + regime stay on one line; rotation lists get space and wrap
	   fully so every sector name is readable */
	.history-table td:nth-child(1),
	.history-table td:nth-child(2) {
		white-space: nowrap;
	}

	.history-table td:nth-child(3),
	.history-table td:nth-child(4) {
		white-space: normal;
		overflow-wrap: normal;
		min-width: 11rem;
		width: 38%;
	}

	.history-table thead th {
		position: sticky;
		top: 0;
		background: #181818;
		z-index: 1;
	}

	.regime-dot {
		display: inline-block;
		width: 0.6em;
		height: 0.6em;
		border-radius: 50%;
		margin-right: 0.5em;
		background: currentColor;
	}

	.regime-dot.risk-on { color: #16c79a; }
	.regime-dot.transitional { color: #f0a500; }
	.regime-dot.risk-off { color: #e94560; }
</style>
