---
import fs from "node:fs";
import path from "node:path";
import { getCollection, getEntry, render } from "astro:content";
import { name, openGraph } from "spectre:globals";
import EarthHero from "../components/EarthHero.astro";
import LandingLayout from "../layouts/LandingLayout.astro";

import regime from "../data/regime/current.json";
import goldSignals from "../data/signals/gold.json";
import silverSignals from "../data/signals/silver.json";

const [posts, about] = await Promise.all([
	getCollection("posts", (post) => post.data.draft !== true),
	getEntry("other", "about"),
]);

const { Content: About } = await render(about!);

// latest weekly rotation snapshot (files are named YYYY-MM-DD.json)
const rotationFiles = import.meta.glob<{
	week_end: string;
	regime: string;
	votes_on: number;
	votes_total: number;
	rotation_in: string[];
	rotation_out: string[];
}>("../data/rotation/*.json", { eager: true, import: "default" });
const rotation = Object.entries(rotationFiles).sort(([a], [b]) =>
	b.localeCompare(a),
)[0][1];

const rotationClass =
	rotation.regime === "Risk-On"
		? "rot-on"
		: rotation.regime === "Risk-Off"
			? "rot-off"
			: "rot-trans";

// atmosphere tint keyed off the public 4-state regime label
const TINTS: Record<string, [number, number, number]> = {
	bull_broad: [63, 214, 143],
	bull_tech: [82, 205, 190],
	correction: [217, 151, 63],
	crisis: [199, 90, 212],
};
const tint = TINTS[regime.label] ?? [127, 178, 228];
const tintCss = `rgb(${tint[0]}, ${tint[1]}, ${tint[2]})`;
const regimeDisplay = regime.label.replace("_", " ").toUpperCase();

// signal feeds, most recent first, shown separately (silver = strategy, gold = ML model)
const silverFeed = [...silverSignals.signals]
	.sort((a, b) => b.date.localeCompare(a.date))
	.slice(0, 6);
const goldFeed = [...goldSignals.signals]
	.sort((a, b) => b.date.localeCompare(a.date))
	.slice(0, 6);

// signals in the trailing 30 days, relative to the regime as-of date
const cutoff = new Date(regime.date);
cutoff.setDate(cutoff.getDate() - 30);
const cutoffStr = cutoff.toISOString().slice(0, 10);
const signals30d =
	silverSignals.signals.filter((s) => s.date >= cutoffStr).length +
	goldSignals.signals.filter((s) => s.date >= cutoffStr).length;

// thesis PDFs from public/thesis (same parsing as the thesis page)
const companyNames: Record<string, string> = {
	ENS: "Ensign Group",
	FIX: "Comfort Systems USA",
	IBKR: "Interactive Brokers",
	JLL: "Jones Lang LaSalle",
	MU: "Micron Technology",
	NVDA: "NVIDIA",
	GD: "General Dynamics",
	PRI: "Primerica",
	INCY: "Incyte",
	NEM: "Newmont",
	TSM: "Taiwan Semiconductor",
	NXPI: "NXP Semiconductors",
};
const thesisDir = path.join(process.cwd(), "public/thesis");
const theses = fs
	.readdirSync(thesisDir)
	.map((file) => {
		const match = file.match(/^public_([A-Z]+)_(\d{4}-\d{2}-\d{2})\.pdf$/);
		if (!match) return null;
		const [, ticker, dateStr] = match;
		return {
			ticker,
			company: companyNames[ticker] || ticker,
			dateStr,
			slug: `${ticker.toLowerCase()}-${dateStr}`,
		};
	})
	.filter((t): t is NonNullable<typeof t> => t !== null)
	.sort((a, b) => b.dateStr.localeCompare(a.dateStr));
const latestTheses = theses.slice(0, 3);

const latestPosts = posts
	.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime())
	.slice(0, 3);

const fmtWeek = (iso: string) =>
	new Date(`${iso}T00:00:00`).toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});
---

<LandingLayout
	title={openGraph.home.title || name}
	description={openGraph.home.description}
	pagefindIgnore
>
	<EarthHero tint={tint} />

	<div class="landing-hero" style={`--regime-tint: ${tintCss}`}>
		<div class="eyebrow">
			<span class="live-chip"><span class="live-dot"></span>{regimeDisplay}</span>
			<span>SYSTEMATIC EQUITY RESEARCH · ~900 US STOCKS · AS OF {regime.date}</span>
			<span id="ut-clock"></span>
		</div>
		<h1>The market,<br />observed</h1>
		<p class="lede">
			Aerondight Systems scores roughly <strong>900 US stocks</strong> daily —
			multi-factor models under a machine-learned regime classifier. The
			classifier currently reads <strong>{regimeDisplay.toLowerCase()}</strong>
			at {Math.round(regime.confidence * 100)}% confidence{regime.agreement
				? ", with both models in agreement"
				: ""}. Every signal is published here, building a track record one
			entry at a time.
		</p>
		<div class="scrollcue">Scroll — the terminator is live</div>
	</div>

	<div class="tiles">
		<div class="tile">
			<div class="lab">Regime</div>
			<div class="val" style={`color: ${tintCss}`}>{regimeDisplay}</div>
			<div class="sub">HMM + validator</div>
		</div>
		<div class="tile">
			<div class="lab">Confidence</div>
			<div class="val">{Math.round(regime.confidence * 100)}<small>%</small></div>
			<div class="sub">{regime.agreement ? "models agree" : "models disagree"}</div>
		</div>
		<div class="tile">
			<div class="lab">Signals · 30d</div>
			<div class="val">{signals30d}</div>
			<div class="sub">silver + gold feeds</div>
		</div>
		<div class="tile">
			<div class="lab">Coverage</div>
			<div class="val">~900</div>
			<div class="sub">S&P 500 + S&P 400</div>
		</div>
	</div>

	<div class="tiles rotation-bar">
		<div class="tile">
			<div class="lab">Week ending</div>
			<div class="val val-date">{fmtWeek(rotation.week_end)}</div>
			<div class="sub">sector rotation · weekly</div>
		</div>
		<div class="tile">
			<div class="lab">Risk status</div>
			<div class={`val ${rotationClass}`}>{rotation.regime.toUpperCase()}</div>
			<div class="sub">{rotation.votes_on}/{rotation.votes_total} votes on</div>
		</div>
		<div class="tile">
			<div class="lab">Rotation in</div>
			{rotation.rotation_in.length ? (
				<div class="sector-chips">
					{rotation.rotation_in.map((s) => (
						<span class="sector-chip chip-in">{s}</span>
					))}
				</div>
			) : (
				<div class="val val-none">—</div>
			)}
			<div class="sub">{rotation.rotation_in.length ? `${rotation.rotation_in.length} confirmed` : "none this week"}</div>
		</div>
		<div class="tile">
			<div class="lab">Rotation out</div>
			{rotation.rotation_out.length ? (
				<div class="sector-chips">
					{rotation.rotation_out.map((s) => (
						<span class="sector-chip chip-out">{s}</span>
					))}
				</div>
			) : (
				<div class="val val-none">—</div>
			)}
			<div class="sub">{rotation.rotation_out.length ? `${rotation.rotation_out.length} confirmed` : "none this week"}</div>
		</div>
	</div>

	<section>
		<div class="eyebrow"><b>LIVE</b> UPDATED DAILY AFTER MARKET CLOSE</div>
		<h2>Instruments</h2>
		<p class="sectionlede">
			Three live systems, each with its own page: what the market is doing, what
			the strategy is buying, and where sector leadership is rotating.
		</p>
		<div class="instruments">
			<a href="/regime" class="instrument">
				<span class="ilab">Regime — Live</span>
				<h3>Market Regime Classification</h3>
				<p>
					HMM + XGBoost system detecting four distinct market states to
					modulate equity scoring.
				</p>
				<span class="istat">Today: <b>{regimeDisplay}</b> · {Math.round(regime.confidence * 100)}% conf</span>
			</a>
			<a href="/silver-alpha" class="instrument">
				<span class="ilab">Silver Alpha — Live</span>
				<h3>Silver Alpha Strategy</h3>
				<p>
					94 trades, 62% win rate, +325% return — full trade log with
					out-of-sample results from 2023–2026.
				</p>
				<span class="istat">Latest signal: <b>{silverFeed[0]?.symbol}</b> · {silverFeed[0]?.date}</span>
			</a>
			<a href="/sector-rotation" class="instrument">
				<span class="ilab">Sector Rotation — Live</span>
				<h3>Sector Rotation</h3>
				<p>
					Weekly market risk status and sector rotation confirmations, updated
					after each Friday close.
				</p>
				<span class="istat">This week: <b>{rotation.regime}</b> · {rotation.votes_on}/{rotation.votes_total} votes</span>
			</a>
		</div>
	</section>

	<section>
		<div class="eyebrow"><b>FEED</b> DATE + SYMBOL · PUBLISHED AS THEY FIRE</div>
		<h2>Recent signals</h2>
		<p class="sectionlede">
			The two live feeds, side by side. Silver is the systematic strategy;
			Gold is the ML alpha model. Full history and outcomes live on the
			Silver Alpha page.
		</p>
		<div class="feeds-grid">
			<div class="feed-col">
				<div class="feed-title"><span class="feed-chip feed-silver">SILVER</span> Strategy signals</div>
				<div class="ledger">
					<div class="lrow lhead"><span>Date</span><span>Symbol</span></div>
					{
						silverFeed.map((s) => (
							<a href="/silver-alpha" class="lrow">
								<span class="ldate">{s.date}</span>
								<span class="lsym">{s.symbol}</span>
							</a>
						))
					}
				</div>
			</div>
			<div class="feed-col">
				<div class="feed-title"><span class="feed-chip feed-gold">GOLD</span> ML model signals</div>
				<div class="ledger">
					<div class="lrow lhead"><span>Date</span><span>Symbol</span></div>
					{
						goldFeed.map((s) => (
							<a href="/silver-alpha" class="lrow">
								<span class="ldate">{s.date}</span>
								<span class="lsym">{s.symbol}</span>
							</a>
						))
					}
				</div>
			</div>
		</div>
		<div class="ledger-note">Signals are published for transparency, not as recommendations.</div>
	</section>

	<section>
		<div class="eyebrow"><b>THESIS</b> AI-GENERATED EQUITY RESEARCH · ~$0.005 PER REPORT</div>
		<h2>Research reports</h2>
		<p class="sectionlede">
			Institutional-style single-ticker reports generated by Aerondight's
			Thesis engine — quantitative signals, fundamentals, and recent news in a
			structured seven-section analysis.
		</p>
		<div>
			{
				latestTheses.map((t) => (
					<a href={`/thesis/${t.slug}`} class="postrow">
						<div class="phead">
							<h3>{t.ticker} — {t.company}</h3>
							<span class="pdate">{t.dateStr}</span>
						</div>
						<p>AI-generated equity research report for {t.company}.</p>
					</a>
				))
			}
		</div>
		<div class="ledger-note"><a href="/thesis">All {theses.length} reports →</a></div>
	</section>

	<section>
		<div class="eyebrow"><b>NOTES</b> METHODOLOGY · BACKTESTS · SAMPLES</div>
		<h2>Latest research</h2>
		<div>
			{
				latestPosts.map((post) => (
					<a href={`/research/${post.id}`} class="postrow">
						<div class="phead">
							<h3>{post.data.title}</h3>
							<span class="pdate">{post.data.createdAt.toLocaleDateString("en-CA")}</span>
						</div>
						<p>{post.data.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section>
		<div class="eyebrow"><b>ABOUT</b> WHO RUNS THIS</div>
		<h2>The Mastermind</h2>
		<div class="about-grid">
			<div class="prose"><About /></div>
			<div class="about-facts">
				<span><b>Since 2024</b> — founder &amp; quantitative researcher</span>
				<span><b>Stack</b> — Python · SQLite · quant modeling</span>
				<span><b>AI</b> — Claude API + GPT API research generation</span>
				<span><a href="/contact">Contact →</a></span>
			</div>
		</div>
	</section>

	<footer>
		AERONDIGHT SYSTEMS · EDUCATIONAL PURPOSES ONLY · NOT INVESTMENT ADVICE<br />
		<b>RENDERED LIVE IN CANVAS · NIGHT SIDE OF EARTH · TERMINATOR TRACKS REAL UT</b>
	</footer>

	<script is:inline>
		const el = document.getElementById("ut-clock");
		function utTick() {
			const n = new Date();
			el.textContent =
				String(n.getUTCHours()).padStart(2, "0") + ":" +
				String(n.getUTCMinutes()).padStart(2, "0") + ":" +
				String(n.getUTCSeconds()).padStart(2, "0") + " UT";
		}
		utTick();
		setInterval(utTick, 1000);
	</script>
</LandingLayout>
